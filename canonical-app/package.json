{
  "name": "rest-express",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx --env-file=.env server/index.ts",
    "dev:with-db": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-with-db.ps1",
    "sync-apks": "node script/sync-apks.js",
    "prebuild": "node scripts/check-migrations.cjs",
    "build": "tsx script/build.ts",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "check": "tsc",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=drizzle.config.ts",
    "db:apply-operational": "node scripts/apply-operational-schema.cjs",
    "db:apply-financial": "node scripts/apply-financial-migration.cjs",
    "db:apply-orphan-recovery": "node scripts/apply-orphan-recovery-migration.cjs",
    "audit:production": "node scripts/production-schema-audit.cjs",
    "db:push": "drizzle-kit push",
    "seed:test-user": "tsx scripts/seed-test-user.ts",
    "otp:expire": "tsx scripts/expire-latest-otp.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "dev:playwright:mock-api": "tsx tests/playwright/support/mock-server.ts",
    "dev:playwright:web": "tsx tests/playwright/support/web-server.ts",
    "test:e2e:local": "node scripts/run-playwright-local.cjs test",
    "test:e2e": "playwright test",
    "test:e2e:live": "cross-env PW_ENV=live PW_WORKERS=1 playwright test --grep @live",
    "test:e2e:admin-live": "cross-env PW_ENV=live PW_WORKERS=1 playwright test --grep @admin-live",
    "test:e2e:staging": "cross-env PW_ENV=staging PW_WORKERS=1 playwright test --grep @live",
    "test:e2e:smoke-live": "cross-env PW_ENV=live PW_WORKERS=1 playwright test --grep @live-smoke",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "smoke:core": "node scripts/smoke-api-patched-flows.cjs",
    "smoke:prod": "node scripts/e2e-production-readiness.cjs",
    "schema:drift": "node scripts/schema-drift-check.cjs",
    "ops:health": "node scripts/ops/health-alert.cjs",
    "load:basic": "node scripts/load-basic-concurrency.cjs"
  },
